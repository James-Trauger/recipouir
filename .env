WEB_PORT=9873
API_PORT=9872

DATABASE_PORT=27017
DATABASE_HOST=mongo-c 

MONGODB_URL=mongodb://127.0.0.1:27017/

# directory containing you're private key and locally trusted certificate relative 
# to this project's location
LOCAL_CERT=/path/to/key/and/certificate

# when running tests, set this to folder containing the private key and certificate
# relative the test file's location
SECRET_PATH=/certs/

# name of the PEM encoded certificate file
CERT_NAME=localhost.pem
# name of the PEM encoded private key file
KEY_NAME=localhost-key.pem